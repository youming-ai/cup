{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "StreamCup design tokens — names align with tailwind.config.js and src/index.css. Import into Figma Variables with modes: dark, light.",
  "color": {
    "night": {
      "$type": "color",
      "$description": "Tailwind: night / CSS: --c-bg",
      "$value": {
        "dark": "#0a0e0c",
        "light": "#f4f7f5"
      }
    },
    "panel": {
      "$type": "color",
      "$description": "Tailwind: panel / CSS: --c-surface",
      "$value": {
        "dark": "#1a221e",
        "light": "#ffffff"
      }
    },
    "panel2": {
      "$type": "color",
      "$description": "Tailwind: panel2 / CSS: --c-surface2",
      "$value": {
        "dark": "#28342e",
        "light": "#e8eeea"
      }
    },
    "line": {
      "$type": "color",
      "$description": "Tailwind: line / CSS: --c-line",
      "$value": {
        "dark": "#304038",
        "light": "#c8d2cd"
      }
    },
    "chalk": {
      "$type": "color",
      "$description": "Tailwind: chalk / CSS: --c-text",
      "$value": {
        "dark": "#f2f7f4",
        "light": "#101814"
      }
    },
    "chalkdim": {
      "$type": "color",
      "$description": "Tailwind: chalkdim / CSS: --c-muted",
      "$value": {
        "dark": "#8a9690",
        "light": "#5a6962"
      }
    },
    "pitch": {
      "$type": "color",
      "$description": "Tailwind: pitch / CSS: --c-pitch — brand accent, positive",
      "$value": {
        "dark": "#2ed573",
        "light": "#22aa5a"
      }
    },
    "live": {
      "$type": "color",
      "$description": "Tailwind: live / CSS: --c-live — broadcast live state",
      "$value": {
        "dark": "#ff453a",
        "light": "#dc322d"
      }
    },
    "amber": {
      "$type": "color",
      "$description": "Tailwind: amber / CSS: --c-amber — halftime / paused",
      "$value": {
        "dark": "#fbbf24",
        "light": "#d99614"
      }
    },
    "overlay": {
      "$type": "color",
      "$description": "Tailwind: overlay — elevation tint. Use overlay/5, overlay/10 for glass controls.",
      "$value": {
        "dark": "#ffffff",
        "light": "#000000"
      }
    },
    "scrim": {
      "$type": "color",
      "$description": "Tailwind: scrim — video badge backdrop. Use scrim/65.",
      "$value": {
        "dark": "#000000",
        "light": "#000000"
      }
    },
    "onscrim": {
      "$type": "color",
      "$description": "Tailwind: onscrim — theme-invariant light foreground for text/icons on the always-black scrim & video overlays.",
      "$value": {
        "dark": "#ffffff",
        "light": "#ffffff"
      }
    },
    "onaccent": {
      "$type": "color",
      "$description": "Tailwind: onaccent — theme-invariant dark foreground for text on the pitch green accent.",
      "$value": {
        "dark": "#0a0e0c",
        "light": "#0a0e0c"
      }
    }
  },
  "radius": {
    "micro": {
      "$type": "dimension",
      "$value": "3px",
      "$description": "Tailwind: rounded-micro / Flags"
    },
    "sm": { "$type": "dimension", "$value": "12px", "$description": "Tailwind: rounded-sm" },
    "card": {
      "$type": "dimension",
      "$value": "16px",
      "$description": "Tailwind: rounded-card / Cards, tables"
    },
    "panel": {
      "$type": "dimension",
      "$value": "24px",
      "$description": "Tailwind: rounded-panel / Header, player"
    },
    "hero": {
      "$type": "dimension",
      "$value": "32px",
      "$description": "Tailwind: rounded-hero / Match detail hero"
    },
    "pill": {
      "$type": "dimension",
      "$value": "9999px",
      "$description": "Tailwind: rounded-pill / Segmented controls"
    }
  },
  "spacing": {
    "page-x": { "$type": "dimension", "$value": "12px", "$description": "Tailwind: px-page-x" },
    "page-x-md": {
      "$type": "dimension",
      "$value": "16px",
      "$description": "Tailwind: md:px-page-x-md"
    },
    "page-y": { "$type": "dimension", "$value": "12px", "$description": "Tailwind: py-page-y" },
    "page-y-md": {
      "$type": "dimension",
      "$value": "16px",
      "$description": "Tailwind: md:py-page-y-md"
    },
    "section": {
      "$type": "dimension",
      "$value": "12px",
      "$description": "Tailwind: space-y-section"
    },
    "stack": { "$type": "dimension", "$value": "8px", "$description": "Tailwind: gap-stack" },
    "card": {
      "$type": "dimension",
      "$value": "12px",
      "$description": "Tailwind: p-card, gap-card"
    },
    "card-inner": {
      "$type": "dimension",
      "$value": "8px",
      "$description": "Tailwind: gap-card-inner"
    }
  },
  "typography": {
    "micro": {
      "$type": "dimension",
      "$value": "9px",
      "$description": "Tailwind: text-micro / ds-micro — form pills"
    },
    "caption": {
      "$type": "dimension",
      "$value": "10px",
      "$description": "Tailwind: text-caption / ds-caption — broadcast labels"
    },
    "label": { "$type": "dimension", "$value": "12px", "$description": "Tailwind: text-label" },
    "font-display": { "$type": "fontFamily", "$value": "Saira Condensed" },
    "font-body": { "$type": "fontFamily", "$value": "Hanken Grotesk" },
    "font-mono": { "$type": "fontFamily", "$value": "ui-monospace" }
  },
  "shadow": {
    "panel": {
      "$type": "shadow",
      "$description": "Tailwind: shadow-panel — cards, tables",
      "$value": {
        "dark": "0 4px 6px -1px rgba(0,0,0,0.25), 0 2px 4px -2px rgba(0,0,0,0.2)",
        "light": "0 2px 4px -1px rgba(0,0,0,0.08), 0 1px 2px -1px rgba(0,0,0,0.06)"
      }
    },
    "hero": {
      "$type": "shadow",
      "$description": "Tailwind: shadow-hero — match detail hero",
      "$value": {
        "dark": "0 10px 15px -3px rgba(0,0,0,0.3), 0 4px 6px -4px rgba(0,0,0,0.2)",
        "light": "0 8px 12px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.08)"
      }
    },
    "float": {
      "$type": "shadow",
      "$description": "Tailwind: shadow-float — dropdowns",
      "$value": {
        "dark": "0 20px 25px -5px rgba(0,0,0,0.35), 0 8px 10px -6px rgba(0,0,0,0.2)",
        "light": "0 16px 20px -5px rgba(0,0,0,0.12), 0 8px 10px -6px rgba(0,0,0,0.08)"
      }
    }
  },
  "component": {
    "ds-page": { "$description": "Page shell padding — px-page-x py-page-y" },
    "ds-page-inner": { "$description": "max-w-6xl mx-auto space-y-section" },
    "ds-glass": {
      "$description": "Glass card — rounded-card border-line/30 bg-panel/85 shadow-panel backdrop-blur-md"
    },
    "ds-glass-hero": {
      "$description": "Hero panel — rounded-panel md:rounded-hero gradient shadow-hero"
    },
    "ds-segmented": {
      "$description": "Capsule track — bg-overlay/5 border-overlay/5 rounded-pill"
    },
    "ds-chip": { "$description": "Filter chip — ds-chip-active / ds-chip-inactive" },
    "ds-scrim-badge": { "$description": "Video overlay badge — bg-scrim/65 backdrop-blur-sm" },
    "ds-caption": { "$description": "Mono caption — font-mono text-caption" },
    "ds-micro": { "$description": "Mono micro — font-mono text-micro (9px)" }
  },
  "alpha": {
    "overlay-5": {
      "$type": "number",
      "$value": 0.05,
      "$description": "bg-overlay/5 — segmented track"
    },
    "overlay-10": {
      "$type": "number",
      "$value": 0.1,
      "$description": "bg-overlay/10 — active tab/chip"
    },
    "line-30": {
      "$type": "number",
      "$value": 0.3,
      "$description": "border-line/30 — glass borders"
    },
    "panel-85": { "$type": "number", "$value": 0.85, "$description": "bg-panel/85 — glass fill" },
    "scrim-65": { "$type": "number", "$value": 0.65, "$description": "bg-scrim/65 — video badges" }
  }
}
